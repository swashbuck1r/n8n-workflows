# Environment variables (may contain secrets)
.env

# n8n local database (workflows are exported to n8n-workflows/ for version control)
.n8n/

# Test outputs (these are generated by run-ci command)
outputs/

# Action checkout directory (used by CloudBees action)
.n8n-action/

# Node modules if using npm
node_modules/

# Temporary test data
.n8n-test/
